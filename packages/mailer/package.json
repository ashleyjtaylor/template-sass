  },
  "dependencies": {
    "@aws-sdk/client-sesv2": "3.1046.0",
    "nodemailer": "7.0.10",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/nodemailer": "7.0.3",
    "typescript": "6.0.3",
    "vitest": "4.1.5"
  }
