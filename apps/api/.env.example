# Copy to .env (gitignored) for local development.
# Production values are injected by ECS from Secrets Manager — see
# infra/cdk/lib/data-stack.ts and infra/cdk/lib/app-stack.ts.

# Match env.ts default but also export it to process.env so libraries that
# read NODE_ENV directly (e.g. better-auth's IP-resolver dev fallback that
# stamps 127.0.0.1 on session.ipAddress) see it.
NODE_ENV=development

BETTER_AUTH_SECRET=local-dev-secret-not-for-production-min-32-chars

# Canonical base URL better-auth uses for OAuth callbacks, email links, and
# session-cookie domains. Local dev: this app's own origin. Production: the
# public API origin (currently the ALB DNS, eventually api.<domain>) — set
# via infra/cdk/lib/app-stack.ts.
BETTER_AUTH_URL=http://localhost:3000

# Allowed origins for both Hono CORS and better-auth's CSRF/trustedOrigins
# check. Postman/curl needs to send `Origin: http://localhost:3000` (or
# whatever the SPA origin will be) for sign-up/sign-in/sign-out to pass —
# better-auth rejects state-changing requests with no Origin header at all
# (MISSING_OR_NULL_ORIGIN) and any Origin not in this list.
CORS_ORIGINS=http://localhost:5174

# Public origin of the apps/web SPA. The billing module builds Stripe
# Checkout success / cancel URLs and the Customer Portal return URL
# relative to this. Vite defaults to :5174 for the web SPA locally.
WEB_BASE_URL=http://localhost:5174

# Stripe — test-mode values for local dev. The Secrets Manager entry
# template-${env}-stripe-secrets supplies the production values via CDK
# (apps + worker tasks). See docs/runbooks/billing-smoke.md for the
# full setup playbook (Stripe CLI install, creating the Pro product /
# price in the test dashboard, etc).
STRIPE_API_KEY=sk_test_replace_me
# Issued by `stripe listen --forward-to localhost:3000/api/webhooks/stripe`
# — copy from the CLI's startup banner.
STRIPE_WEBHOOK_SECRET=whsec_replace_me
# The price id of the Pro product in your Stripe test-mode dashboard.
STRIPE_PRICE_ID_PRO=price_replace_me
# Where Stripe sends the user after they close the Customer Portal.
# Defaults to the web origin; override per env via CDK in deployed envs.
STRIPE_PORTAL_RETURN_URL=http://localhost:5174
