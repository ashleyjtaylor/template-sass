{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended", ":semanticCommits", "group:monorepos", "group:recommended"],
  "schedule": ["before 4am on monday"],
  "packageRules": [
    {
      "matchUpdateTypes": ["major"],
      "schedule": ["before 4am on the first day of the month"]
    },
    {
      "groupName": "aws-cdk",
      "matchPackageNames": ["aws-cdk", "aws-cdk-lib", "constructs"]
    }
  ],
  "lockFileMaintenance": {
    "enabled": true,
    "automerge": false
  }
}
