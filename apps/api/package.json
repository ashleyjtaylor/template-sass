{
  "name": "@template/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24.15.0"
  },
  "scripts": {
    "dev": "tsx watch --env-file-if-exists=.env src/index.ts",
    "build": "tsc -p tsconfig.build.json && tsc-alias -p tsconfig.build.json",
    "start": "node dist/index.js",
    "typecheck": "tsc",
    "test": "vitest run"
  },
  "dependencies": {
    "@hono/node-server": "2.0.1",
    "@template/billing": "workspace:*",
    "@template/db": "workspace:*",
    "@template/errors": "workspace:*",
    "better-auth": "1.6.9",
    "hono": "4.12.18",
    "pino": "10.3.1",
    "stripe": "22.1.1",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/node": "24.12.3",
    "pino-pretty": "13.1.3",
    "tsc-alias": "1.8.17",
    "tsx": "4.21.0",
    "typescript": "6.0.3",
    "vitest": "4.1.5"
  }
}
